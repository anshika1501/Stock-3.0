# ============================
# Global Environment Variables
# Shared by Docker Compose for both backend and frontend
# ============================

# --- Backend (Django) ---
DJANGO_SECRET_KEY=change-me-to-a-real-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# --- Frontend (Next.js) ---
# In Docker, the frontend container talks to the backend container via the service name
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# --- Google GenAI (used by frontend Genkit) ---
GOOGLE_GENAI_API_KEY=your-google-genai-api-key-here
